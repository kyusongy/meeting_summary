# Deepgram API key for speech-to-text transcription
# Get one at https://console.deepgram.com/
DEEPGRAM_API_KEY=

# OpenRouter API key for LLM summarization
# Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Which model to use for summarization (OpenRouter model ID)
OPENROUTER_MODEL=x-ai/grok-4.1-fast
